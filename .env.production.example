# Production Environment Variables for Railway

# ============================================
# Server Configuration
# ============================================
ENVIRONMENT=production
PORT=8000
LOG_LEVEL=info

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string (Supabase Postgres URI)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase (for vector search and knowledge base)
SUPABASE_DB_URL=postgresql://user:password@supabase-host/postgres
SUPABASE_API_KEY=your-supabase-api-key

# ============================================
# Redis Configuration
# ============================================
# Redis connection string (Upstash Redis URI - TLS recommended)
REDIS_URL=rediss://default:password@host:port

# Redis SSL (for Upstash)
REDIS_SSL=true
UPSTASH_REDIS_URL=rediss://default:password@host:port

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: use separate key for embedding if needed
OPENAI_API_EMBEDDING_KEY=
# Note: chat temperature is currently hardcoded to 0.2 in graph/tools.py

# ============================================
# LangSmith Configuration (Optional)
# ============================================
LANGSMITH_API_KEY=ls_xxxx
LANGSMITH_PROJECT=thcs-giathanh
LANGSMITH_TRACING=false  # Set to true for debugging

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Use either SMTP_USERNAME or SMTP_USER
SMTP_USERNAME=your-email@gmail.com
# SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMERGENCY_EMAIL_RECIPIENTS=teacher1@gmail.com,teacher2@gmail.com

# ============================================
# Facebook Admin Configuration
# ============================================
# Comma-separated list of Facebook PSIDs authorized to use #resume command
ADMIN_FACEBOOK_PSIDS=123456789,987654321

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=https://thcs-giathanh-fe.up.railway.app,https://yourdomain.com
ALLOWED_CREDENTIALS=true
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=*
EXPOSE_HEADERS=
ALLOWED_ORIGIN_REGEX=
CORS_MAX_AGE=600
# WebSocket origin policy
# false: allow clients without Origin header (wscat/mobile/non-browser)
# true: require Origin and validate against ALLOWED_ORIGINS / ALLOWED_ORIGIN_REGEX
WS_REQUIRE_ORIGIN=false

# ============================================
# API Configuration
# ============================================
API_TITLE=THCS GIA THANH - Counseling Bot API
API_VERSION=1.0.0
API_DESCRIPTION=AI-powered counseling chatbot for students

# ============================================
# Session & Cache Configuration
# ============================================
SESSION_TIMEOUT=7200  # 2 hours
CACHE_TTL=3600  # 1 hour
HISTORY_TTL=604800  # 7 days

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
